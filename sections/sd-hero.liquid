{% comment %}
  SHOPDURAS — Hero Section
  Archivo: sections/sd-hero.liquid
  Cómo usar: En el editor de temas, agregar como sección
  personalizada en la página de inicio.
{% endcomment %}

<section class="sd-hero" id="sd-hero-{{ section.id }}">
  <div class="sd-hero__bg">
    {%- if section.settings.background_image != blank -%}
      <img
        src="{{ section.settings.background_image | image_url: width: 1600 }}"
        alt="{{ section.settings.background_image.alt | escape }}"
        class="sd-hero__bg-img"
        loading="eager"
        fetchpriority="high"
        width="1600"
        height="800"
      >
    {%- endif -%}
    <div class="sd-hero__overlay"></div>
  </div>

  <div class="sd-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="sd-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h1 class="sd-hero__title">{{ section.settings.title | newline_to_br }}</h1>

    {%- if section.settings.subtitle != blank -%}
      <p class="sd-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.show_price_badge -%}
      <div class="sd-hero__price-badge">
        <span class="sd-hero__price-label">Desde</span>
        <span class="sd-hero__price-value">{{ section.settings.price_from }}</span>
        {%- if section.settings.price_compare != blank -%}
          <span class="sd-hero__price-compare">{{ section.settings.price_compare }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="sd-hero__cta-row">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url }}" class="sd-btn sd-btn--gold sd-hero__cta-primary">
          {{ section.settings.cta_primary_label }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_label != blank -%}
        <a href="{{ section.settings.cta_secondary_url }}" class="sd-btn sd-btn--outline sd-hero__cta-secondary">
          {{ section.settings.cta_secondary_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_trust_pills -%}
      <div class="sd-hero__trust">
        <div class="sd-hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1.5l1.8 3.6 4 .58-2.9 2.83.68 3.98L8 10.35l-3.58 1.88.68-3.98L2.2 5.68l4-.58L8 1.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
          Calidad garantizada
        </div>
        <div class="sd-hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 5h12l-1 7H3L2 5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M5 5V4a3 3 0 016 0v1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          Pago 100% seguro
        </div>
        <div class="sd-hero__trust-item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1" y="4" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M1 7h14" stroke="currentColor" stroke-width="1.4"/></svg>
          Envío a toda Honduras
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #sd-hero-{{ section.id }} {
    --hero-height: {{ section.settings.height }}px;
    --hero-align: {{ section.settings.content_align }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --text-color: {{ section.settings.text_color }};
  }

  .sd-hero {
    position: relative;
    min-height: var(--hero-height, 560px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .sd-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .sd-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sd-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10, var(--overlay-opacity, .5));
  }

  .sd-hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
    text-align: var(--hero-align, left);
    color: var(--text-color, #fff);
  }

  .sd-hero__eyebrow {
    display: inline-block;
    font-family: var(--sd-font-ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: var(--sd-gold);
    color: var(--sd-black);
    padding: 4px 12px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .sd-hero__title {
    font-family: var(--sd-font-display);
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 500;
    line-height: 1.06;
    letter-spacing: -0.03em;
    max-width: 680px;
    margin-bottom: 16px;
  }
  {% if section.settings.content_align == 'center' %}
  .sd-hero__title { margin-left: auto; margin-right: auto; }
  {% endif %}

  .sd-hero__subtitle {
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.6;
    opacity: 0.85;
    max-width: 480px;
    margin-bottom: 28px;
  }
  {% if section.settings.content_align == 'center' %}
  .sd-hero__subtitle { margin-left: auto; margin-right: auto; }
  {% endif %}

  .sd-hero__price-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.25);
    backdrop-filter: blur(8px);
    border-radius: var(--sd-radius-md);
    padding: 10px 18px;
    margin-bottom: 24px;
  }
  .sd-hero__price-label {
    font-family: var(--sd-font-ui);
    font-size: 12px;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .sd-hero__price-value {
    font-family: var(--sd-font-ui);
    font-size: 28px;
    font-weight: 700;
    color: var(--sd-gold);
  }
  .sd-hero__price-compare {
    font-family: var(--sd-font-ui);
    font-size: 16px;
    text-decoration: line-through;
    opacity: 0.5;
  }

  .sd-hero__cta-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    {% if section.settings.content_align == 'center' %}
    justify-content: center;
    {% endif %}
  }

  .sd-hero__cta-primary {
    font-size: 15px;
    padding: 14px 28px;
  }
  .sd-hero__cta-secondary {
    font-size: 15px;
    padding: 14px 28px;
    border-color: rgba(255,255,255,.5);
    color: #fff;
  }
  .sd-hero__cta-secondary:hover {
    background: rgba(255,255,255,.15);
    color: #fff;
  }

  .sd-hero__trust {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 32px;
    flex-wrap: wrap;
    {% if section.settings.content_align == 'center' %}
    justify-content: center;
    {% endif %}
  }
  .sd-hero__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    opacity: 0.75;
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .sd-hero__content { padding: 48px 16px; }
    .sd-hero__cta-row { flex-direction: column; align-items: flex-start; }
    {% if section.settings.content_align == 'center' %}
    .sd-hero__cta-row { align-items: center; }
    {% endif %}
    .sd-hero__trust { gap: 12px; }
  }
</style>

{% schema %}
{
  "name": "SD Hero",
  "tag": "section",
  "class": "sd-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto eyebrow (encima del título)",
      "default": "Oferta especial esta semana"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Título principal",
      "default": "Lo que necesitás,\nal mejor precio."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Gadgets, herramientas, suplementos y más. Entrega rápida a toda Honduras."
    },
    {
      "type": "header",
      "content": "Precio / Badge"
    },
    {
      "type": "checkbox",
      "id": "show_price_badge",
      "label": "Mostrar badge de precio",
      "default": false
    },
    {
      "type": "text",
      "id": "price_from",
      "label": "Precio desde",
      "default": "L. 199"
    },
    {
      "type": "text",
      "id": "price_compare",
      "label": "Precio comparado (tachado)",
      "default": "L. 450"
    },
    {
      "type": "header",
      "content": "Botones CTA"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Botón principal — texto",
      "default": "Ver ofertas de hoy"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Botón principal — enlace"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Botón secundario — texto",
      "default": "Explorar categorías"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Botón secundario — enlace"
    },
    {
      "type": "header",
      "content": "Imagen de fondo"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Imagen de fondo"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Opacidad del overlay",
      "default": 50
    },
    {
      "type": "header",
      "content": "Opciones de diseño"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Alineación del contenido",
      "options": [
        { "value": "left",   "label": "Izquierda" },
        { "value": "center", "label": "Centro" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Altura del hero",
      "default": 580
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "show_trust_pills",
      "label": "Mostrar pills de confianza",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "SD Hero"
    }
  ]
}
{% endschema %}
